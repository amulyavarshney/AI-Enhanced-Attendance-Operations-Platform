# PostgreSQL Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/attendance_db

# App environment: development | production
APP_ENV=development

# JWT auth (required in production — change this secret)
JWT_SECRET_KEY=dev-only-change-me-in-production
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_DAYS=14

# AI endpoint rate limiting
AI_RATE_LIMIT_MAX=20
AI_RATE_LIMIT_WINDOW_SECONDS=60

# AI circuit breaker
AI_CIRCUIT_FAILURE_THRESHOLD=3
AI_CIRCUIT_RECOVERY_SECONDS=60

# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_API_VERSION=2023-07-01-preview
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_MODEL=gpt-4o

# API Configuration
API_PORT=8000
# Required for /admin/reset-database (disabled when APP_ENV=production)
ADMIN_API_KEY=change-me-dev-reset-key

# Comma-separated allowed origins (used in production; development also allows these)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Frontend Configuration
VITE_API_URL=http://localhost:8000
